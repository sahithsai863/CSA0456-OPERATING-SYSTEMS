#include <stdio.h>

int main()
{
    int n, i;
    int bt[20], remaining[20];
    int wt[20] = {0}, tat[20];
    int time_quantum;
    int time = 0, done;

    float avg_wt = 0, avg_tat = 0;

    printf("Enter the number of processes: ");
    scanf("%d", &n);

    /* Input burst times */
    for (i = 0; i < n; i++)
    {
        printf("Enter Burst Time for Process P%d: ", i + 1);
        scanf("%d", &bt[i]);
        remaining[i] = bt[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &time_quantum);

    /* Round Robin Scheduling */
    do
    {
        done = 1;

        for (i = 0; i < n; i++)
        {
            if (remaining[i] > 0)
            {
                done = 0;

                if (remaining[i] > time_quantum)
                {
                    time += time_quantum;
                    remaining[i] -= time_quantum;
                }
                else
                {
                    time += remaining[i];

                    /* Waiting Time = Completion Time - Burst Time */
                    wt[i] = time - bt[i];

                    remaining[i] = 0;
                }
            }
        }
    } while (!done);

    /* Calculate Turnaround Time */
    for (i = 0; i < n; i++)
    {
        tat[i] = bt[i] + wt[i];
        avg_wt += wt[i];
        avg_tat += tat[i];
    }

    /* Display Results */
    printf("\nProcess\tBurst Time\tWaiting Time\tTurnaround Time\n");

    for (i = 0; i < n; i++)
    {
        printf("P%d\t%d\t\t%d\t\t%d\n",
               i + 1, bt[i], wt[i], tat[i]);
    }

    /* Calculate Averages */
    avg_wt /= n;
    avg_tat /= n;

    printf("\nAverage Waiting Time    = %.2f", avg_wt);
    printf("\nAverage Turnaround Time = %.2f\n", avg_tat);

    return 0;
}
