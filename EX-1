#include <stdio.h>
#include <windows.h>

int main()
{
    STARTUPINFO si;
    PROCESS_INFORMATION pi;

    // Initialize structures
    ZeroMemory(&si, sizeof(si));
    si.cb = sizeof(si);
    ZeroMemory(&pi, sizeof(pi));

    // Display current process ID
    printf("Current Process ID (PID): %lu\n", GetCurrentProcessId());

    // Create a child process (opens Notepad)
    if (!CreateProcess(
            "C:\\Windows\\System32\\notepad.exe", // Program to execute
            NULL,        // Command line arguments
            NULL,        // Process security attributes
            NULL,        // Thread security attributes
            FALSE,       // Inherit handles
            0,           // Creation flags
            NULL,        // Environment
            NULL,        // Current directory
            &si,         // Startup info
            &pi))        // Process information
    {
        printf("Process creation failed. Error code: %lu\n", GetLastError());
        return 1;
    }

    // Display child process ID
    printf("Child Process Created Successfully!\n");
    printf("Child Process ID (PID): %lu\n", pi.dwProcessId);

    // Wait for the child process to terminate
    WaitForSingleObject(pi.hProcess, INFINITE);

    printf("Child process has terminated.\n");

    // Close handles
    CloseHandle(pi.hProcess);
    CloseHandle(pi.hThread);

    return 0;
}
