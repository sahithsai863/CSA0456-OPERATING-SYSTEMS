#include <stdio.h>

int main()
{
    int n, i, time = 0, completed = 0;
    int bt[20], remaining[20], priority[20];
    int wt[20], tat[20];
    float avg_wt = 0, avg_tat = 0;

    printf("Enter the number of processes: ");
    scanf("%d", &n);

    /* Input burst times and priorities */
    for (i = 0; i < n; i++)
    {
        printf("Enter Burst Time for Process P%d: ", i + 1);
        scanf("%d", &bt[i]);

        printf("Enter Priority for Process P%d (smaller number = higher priority): ", i + 1);
        scanf("%d", &priority[i]);

        remaining[i] = bt[i];
    }

    /* Preemptive scheduling simulation */
    while (completed < n)
    {
        int highest = -1;

        /* Find the ready process with highest priority */
        for (i = 0; i < n; i++)
        {
            if (remaining[i] > 0)
            {
                if (highest == -1 ||
                    priority[i] < priority[highest] ||
                    (priority[i] == priority[highest] && i < highest))
                {
                    highest = i;
                }
            }
        }

        /* Execute selected process for one time unit */
        remaining[highest]--;
        time++;

        /* If process finishes */
        if (remaining[highest] == 0)
        {
            completed++;

            tat[highest] = time;               /* Arrival time = 0 */
            wt[highest] = tat[highest] - bt[highest];

            avg_wt += wt[highest];
            avg_tat += tat[highest];
        }
    }

    /* Display results */
    printf("\nProcess\tPriority\tBurst Time\tWaiting Time\tTurnaround Time\n");

    for (i = 0; i < n; i++)
    {
        printf("P%d\t%d\t\t%d\t\t%d\t\t%d\n",
               i + 1,
               priority[i],
               bt[i],
               wt[i],
               tat[i]);
    }

    /* Calculate averages */
    avg_wt /= n;
    avg_tat /= n;

    printf("\nAverage Waiting Time    = %.2f", avg_wt);
    printf("\nAverage Turnaround Time = %.2f\n", avg_tat);

    return 0;
}
